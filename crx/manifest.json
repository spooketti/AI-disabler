{
  "name": "AI-Browser Blocker",
  "description": "if your URL is one of the AI sites it redirects",
  "version": "1.1",
  "manifest_version": 3,
  "permissions": [
      "activeTab",
      "scripting",
      "storage"
  ],
  "host_permissions": [
      "https://chatgpt.com/*",
      "https://gemini.google.com/*"
  ],
  "content_scripts": [
      {
          "matches": [
              "https://chatgpt.com/*",
              "https://gemini.google.com/*"
          ],
          "js": ["content.js"]
      }
  ]
}
